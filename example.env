# Application Configuration
VERSION=1.0.0
API_VERSION=v1

# Logging Configuration
LOG_LEVEL=info

# Application Mode: development, production, testing
MODE=development
SERVICE_NAME=skoolz

# Server
HTTP_PORT=9090

# Health Check Configuration
HEALTH_CHECK_ROUTE=/health

# JWT Configuration
JWT_SECRET=SKooLLZ@!!22
SERVICE_BASE_PATH=/api/v1

# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_DATABASE=skoolz_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
POSTGRES_SSL=false
POSTGRES_MAX_POOL_SIZE=10
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_CONN_IDLE_TIME_MS=300000

# Redis Cache Configuration (optional — app continues without cache if unreachable)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE=5

# CORS
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173
